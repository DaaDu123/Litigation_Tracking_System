@page "/reset-password"
@layout LTSFrontend.Layout.LoginLayout
@using LTSFrontend.Core.Exceptions
@using LTSFrontend.Features.Auth.Models
@using LTSFrontend.Features.Auth.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Reset Password - LTS</PageTitle>

<h2>Reset Password</h2>
<p class="auth-subtitle">
    Enter the OTP code sent to <strong>@_model.Email</strong> along with your new password.
</p>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger py-2" style="white-space: pre-line;">@_errorMessage</div>
}
@if (!string.IsNullOrWhiteSpace(_infoMessage))
{
    <div class="alert alert-success py-2">@_infoMessage</div>
}

@if (!_resetDone)
{
    <EditForm Model="_model" OnValidSubmit="HandleResetAsync">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" @bind="_model.Email" @bind:event="oninput" required />
            <ValidationMessage For="() => _model.Email" class="text-danger small" />
        </div>

        <div class="mb-3">
            <label class="form-label">OTP Code</label>
            <input type="text" class="form-control auth-otp-input" maxlength="6" placeholder="------"
                   @bind="_model.OtpCode" @bind:event="oninput" required />
            <ValidationMessage For="() => _model.OtpCode" class="text-danger small" />
        </div>

        <div class="mb-3 password-toggle-wrap">
            <label class="form-label">New Password</label>
            <input type="@(_showPassword ? "text" : "password")" class="form-control"
                   placeholder="At least 8 characters, mixed case, number & symbol"
                   @bind="_model.NewPassword" @bind:event="oninput" required />
            <button type="button" class="password-toggle-btn" tabindex="-1" @onclick="() => _showPassword = !_showPassword">
                <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
            </button>
            <ValidationMessage For="() => _model.NewPassword" class="text-danger small" />
        </div>

        <div class="mb-3 password-toggle-wrap">
            <label class="form-label">Confirm New Password</label>
            <input type="@(_showConfirmPassword ? "text" : "password")" class="form-control"
                   placeholder="Re-enter your new password"
                   @bind="_model.ConfirmPassword" @bind:event="oninput" required />
            <button type="button" class="password-toggle-btn" tabindex="-1" @onclick="() => _showConfirmPassword = !_showConfirmPassword">
                <i class="bi @(_showConfirmPassword ? "bi-eye-slash" : "bi-eye")"></i>
            </button>
            <ValidationMessage For="() => _model.ConfirmPassword" class="text-danger small" />
        </div>

        <button type="submit" class="btn btn-auth-primary" disabled="@_isBusy">
            @if (_isBusy)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Reset Password
        </button>
    </EditForm>

    <div class="auth-footer">
        Didn't get the code?
        <button type="button" class="btn btn-link auth-link p-0 border-0 align-baseline"
                disabled="@_isResending" @onclick="HandleResendAsync">
            @(_isResending ? "Sending..." : "Resend OTP")
        </button>
    </div>
}
else
{
    <div class="auth-footer">
        <a class="auth-link" href="/login">Continue to Sign In</a>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    private readonly ResetPasswordRequest _model = new();
    private bool _isBusy;
    private bool _isResending;
    private bool _resetDone;
    private bool _showPassword;
    private bool _showConfirmPassword;
    private string? _errorMessage;
    private string? _infoMessage;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(Email))
            _model.Email = Email;
    }

    private async Task HandleResetAsync()
    {
        _errorMessage = null;
        _infoMessage = null;
        _isBusy = true;
        try
        {
            var result = await AuthService.ResetPasswordAsync(_model);
            _infoMessage = result.Message;
            _resetDone = true;
        }
        catch (ApiException ex)
        {
            _errorMessage = ex.GetFullMessage();
        }
        catch (Exception)
        {
            _errorMessage = "Password reset could not be completed. Please try again.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task HandleResendAsync()
    {
        _errorMessage = null;
        _infoMessage = null;

        if (string.IsNullOrWhiteSpace(_model.Email))
        {
            _errorMessage = "Please enter your email first.";
            return;
        }

        _isResending = true;
        try
        {
            var result = await AuthService.ForgotPasswordAsync(new ForgotPasswordRequest { Email = _model.Email });
            _infoMessage = result.Message;
        }
        catch (ApiException ex)
        {
            _errorMessage = ex.GetFullMessage();
        }
        catch (Exception)
        {
            _errorMessage = "OTP resend nahi ho saka. Please try again.";
        }
        finally
        {
            _isResending = false;
        }
    }
}
