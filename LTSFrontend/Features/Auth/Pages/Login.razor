@page "/login"
@layout LTSFrontend.Layout.LoginLayout
@using LTSFrontend.Core.Auth
@using LTSFrontend.Core.Exceptions
@using LTSFrontend.Features.Auth.Models
@using LTSFrontend.Features.Auth.Services
@using LTSFrontend.Features.Users.Services
@using LTSFrontend.State
@using Microsoft.AspNetCore.Components.Authorization
@inject IAuthService AuthService
@inject IUserService UserService
@inject UserSessionState Session
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

@rendermode InteractiveServer
<PageTitle>Login - LTS</PageTitle>

<h2>Welcome Back!</h2>
<p class="auth-subtitle">Sign in to continue</p>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger py-2">@_errorMessage</div>
}

@* 🔴 FIX 2: FormName="LoginForm" add kiya *@
<EditForm Model="_model" FormName="LoginForm" OnValidSubmit="HandleLoginAsync">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Email / Username</label>
        <input type="email" class="form-control" placeholder="Enter your email address"
               @bind="_model.Email" @bind:event="oninput" required />
        <ValidationMessage For="() => _model.Email" class="text-danger small" />
    </div>

    <div class="mb-2 password-toggle-wrap">
        <label class="form-label">Password</label>
        <input type="@(_showPassword ? "text" : "password")" class="form-control"
               placeholder="Enter your password"
               @bind="_model.Password" @bind:event="oninput" required />
        <button type="button" class="password-toggle-btn" tabindex="-1" @onclick="() => _showPassword = !_showPassword">
            <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
        </button>
        <ValidationMessage For="() => _model.Password" class="text-danger small" />
    </div>

    <div class="text-end mb-3">
        <a class="auth-link" href="/forgot-password">Forgot Password?</a>
    </div>

    <button type="submit" class="btn btn-auth-primary" disabled="@_isBusy">
        @if (_isBusy)
        {
            <span class="spinner-border spinner-border-sm me-2"></span>
        }
        Sign In
    </button>
</EditForm>

<div class="auth-footer">
    Don't have an account? <a class="auth-link" href="/register">Register here</a>
    <br />
    &copy; @DateTime.Now.Year LTS. All rights reserved.
</div>

@code {
    private readonly LoginRequest _model = new();
    private bool _isBusy;
    private bool _showPassword;
    private string? _errorMessage;

    private async Task HandleLoginAsync()
    {
        _errorMessage = null;
        _isBusy = true;
        try
        {
            var result = await AuthService.LoginAsync(_model);

            var provider = (CustomAuthStateProvider)AuthStateProvider;
            await provider.MarkUserAsAuthenticatedAsync(
                result.UserID, result.FullName, result.Email, null,
                result.AccessToken, result.AccessTokenExpiry);

            string? role = null;
            try
            {
                var profile = await UserService.GetMyProfileAsync();
                role = profile?.RoleName;
            }
            catch
            {
                // Non-fatal: user stays logged in without a role claim.
            }

            await provider.MarkUserAsAuthenticatedAsync(
                result.UserID, result.FullName, result.Email, role,
                result.AccessToken, result.AccessTokenExpiry);

            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (ApiException ex)
        {
            _errorMessage = ex.GetFullMessage();
        }
        catch (Exception)
        {
            _errorMessage = "Could not Login. Please try again.";
        }
        finally
        {
            _isBusy = false;
        }
    }
}