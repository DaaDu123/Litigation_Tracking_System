@page "/forgot-password"
@layout LTSFrontend.Layout.LoginLayout
@using LTSFrontend.Core.Exceptions
@using LTSFrontend.Features.Auth.Models
@using LTSFrontend.Features.Auth.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Forgot Password - LTS</PageTitle>

<h2>Forgot Password</h2>
<p class="auth-subtitle">Enter your account email and we'll send you a 6-digit OTP to reset your password.</p>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger py-2">@_errorMessage</div>
}
@if (!string.IsNullOrWhiteSpace(_infoMessage))
{
    <div class="alert alert-success py-2">@_infoMessage</div>
}

@if (!_otpSent)
{
    <EditForm Model="_model" OnValidSubmit="HandleSendOtpAsync">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" placeholder="Enter your registered email address"
                   @bind="_model.Email" @bind:event="oninput" required />
            <ValidationMessage For="() => _model.Email" class="text-danger small" />
        </div>

        <button type="submit" class="btn btn-auth-primary" disabled="@_isBusy">
            @if (_isBusy)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Send OTP
        </button>
    </EditForm>
}

<div class="auth-footer">
    Remembered your password? <a class="auth-link" href="/login">Back to Sign In</a>
</div>

@code {
    private readonly ForgotPasswordRequest _model = new();
    private bool _isBusy;
    private bool _otpSent;
    private string? _errorMessage;
    private string? _infoMessage;

    private async Task HandleSendOtpAsync()
    {
        _errorMessage = null;
        _infoMessage = null;
        _isBusy = true;
        try
        {
            var result = await AuthService.ForgotPasswordAsync(_model);
            _infoMessage = result.Message;
            _otpSent = true;

            // Move to the reset-password screen with the email pre-filled.
            Navigation.NavigateTo($"/reset-password?email={Uri.EscapeDataString(_model.Email)}");
        }
        catch (ApiException ex)
        {
            _errorMessage = ex.GetFullMessage();
        }
        catch (Exception)
        {
            _errorMessage = "Request could not be completed. Please try again.";
        }
        finally
        {
            _isBusy = false;
        }
    }
}
